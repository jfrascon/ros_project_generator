# https://docs.docker.com/compose/environment-variables/#the-env-file
services:
  {{ service }}:
    image: {{ img_id }}

    # The container starts as root because the robotics_dockers entrypoint uses HOST_UID /
    # HOST_UPGID and gosu to switch to the effective development user.
    user: root

    privileged: false

    # Keep only if you really need to create or modify network interfaces
    # inside the container.
    cap_add:
      - NET_ADMIN # Be able to create network devices inside the container

    # ROS2/DDS development is usually simpler with host networking,
    # especially for discovery, multicast/unicast and robot/sensor networks.
    network_mode: host

    # Gives the container a larger private /dev/shm.
    # This is useful for ROS2, Gazebo, RViz, cameras, OpenCV,
    # Python multiprocessing and large DDS messages.
    # Ref: https://docs.nvidia.com/deeplearning/frameworks/user-guide/index.html#setincshmem
    shm_size: "2gb"

    # Enable only if shared-memory IPC between host and container is required.
    # Usually not needed when all ROS2 nodes run inside the same container.
    # ipc: host

    working_dir: {{ img_workspace_dir }}
    tty: true
    stdin_open: true

    volumes:
      # +------------------+
      # | Project mappings |
      # +------------------+
      - {{ workspace_dir }}:{{ img_workspace_dir }}
      # +------------------+
      # | Dataset mappings |
      # +------------------+
      #- ~/datasets:{{ img_datasets_dir }}
      # +-------------------+
      # | Graphics mappings |
      # +-------------------+
      - /tmp/.cookies.xauth:/tmp/.cookies.xauth:rw
      - /tmp/.X11-unix:/tmp/.X11-unix:rw
      # +-----------------+
      # | Device mappings |
      # +-----------------+
      - /dev/input:/dev/input
      # +-----------------+
      # | Custom mappings |
      # +-----------------+
      # Folders
      #- ~/.ssh:{{ img_ssh_dir }}:ro
      # Files
      {% if use_git %}
      - {{ gitconfig_file }}:{{ img_gitconfig_file }}:ro
      {% endif %}

    devices:
      # - /dev/ttyACM0:/dev/ttyACM0
      - /dev/bus/usb:/dev/bus/usb
      - /dev/dri:/dev/dri
    #device_cgroup_rules:
    #  - "c 13:* rmw" # input
    #  - "c 166:* rmw" # ttyACM
    #  - "c 180:* rmw" # usb
    #  - "c 189:* rmw" # usb_device

    environment:
      - DISPLAY=${DISPLAY}
      - QT_X11_NO_MITSHM=1
      - TERM=${TERM:-xterm-256color}
      - XAUTHORITY=/tmp/.cookies.xauth
      {% if use_host_nvidia_driver %}
      - NVIDIA_VISIBLE_DEVICES=all
      - NVIDIA_DRIVER_CAPABILITIES=all
      {% endif %}

      # Used by the entrypoint to remap the container user and then exec with gosu.
      - HOST_UID={{ host_uid }}
      - HOST_UPGID={{ host_upgid }}

    # init: true enables a tiny init (tini) as PID 1 inside the container.
    # It forwards signals (SIGTERM/SIGINT) to the app and reaps zombie
    # processes from child workers, preventing dirty shutdowns and resource
    # leaks.
    #
    # It is not a supervisor: it will not restart your app. It only fixes
    # PID-1 semantics.
    #
    # Recommended for services that spawn subprocesses or use launchers/daemons,
    # for example ros2 launch, drivers, simulators and agent tooling.
    init: true

    # Add the GID of the render device group so that all container processes
    # (including those opened by VS Code) can access /dev/dri/renderD* for
    # GPU-accelerated rendering (Gazebo, RViz, OpenGL).
    #
    # How to find the value for your machine:
    #   stat -c %g /dev/dri/renderD128
    #
    # How to provide RENDER_GID (choose one):
    #   1. .env file next to this docker-compose file:
    #        RENDER_GID=992
    #   2. Export in your shell before running docker compose:
    #        export RENDER_GID=$(stat -c %g /dev/dri/renderD128)
    #   3. Inline when running docker compose:
    #        RENDER_GID=$(stat -c %g /dev/dri/renderD128) docker compose up
    #
    # This is required because modifying /etc/group at runtime (entrypoint) is
    # not enough: processes started by VS Code do not inherit late group changes.
    group_add:
      - "${RENDER_GID?RENDER_GID must be set. Run: stat -c %g /dev/dri/renderD128}"
