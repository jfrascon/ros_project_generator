{
    "version": "2.0.0",
    "tasks": [
        {
            // Builds the entire workspace in Release mode.
            // This is the default task — runs with Ctrl+Shift+B.
            // rosbuild injects: --mixin release compile-commands, --merge-install,
            // --symlink-install, --parallel-workers (half of available cores),
            // and CMAKE_CXX_FLAGS with standard warning flags.
            // The generated compile_commands.json is picked up by IntelliSense automatically.
            "label": "build Release",
            "detail": "colcon build --mixin release compile-commands (default rosbuild flags)",
            "type": "shell",
            "command": "rosbuild",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Builds the entire workspace with debug symbols (-g, no optimization).
            // Use this when you need to attach a debugger (gdb / VS Code debugger)
            // to a running node and inspect variables, breakpoints, and call stacks.
            // Binaries are larger and slower than Release.
            "label": "build Debug",
            "detail": "colcon build --mixin debug compile-commands",
            "type": "shell",
            "command": "rosbuild --mixin debug",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Builds the entire workspace with both release optimizations and debug symbols.
            // The best of both worlds: performance close to Release, but with enough
            // debug information to get meaningful stack traces and breakpoints.
            // Recommended when profiling or investigating issues in production-like conditions.
            "label": "build RelWithDebInfo",
            "detail": "colcon build --mixin rel-with-deb-info compile-commands",
            "type": "shell",
            "command": "rosbuild --mixin rel-with-deb-info",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Removes build/, install/ and log/ from the workspace root.
            // Forces a full rebuild on the next build task.
            // Uses colcon clean workspace -y (the -y skips the confirmation prompt).
            // WARNING: after cleaning, IntelliSense loses compile_commands.json
            // and falls back to the includePath / compilerArgs fallback in c_cpp_properties.json
            // until the next successful build regenerates it.
            "label": "clean",
            "detail": "Remove build/, install/ and log/ folders",
            "type": "shell",
            "command": "colcon clean workspace -y",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Prints the value of all VS Code predefined variables to the terminal.
            // Useful for debugging tasks.json commands that use ${workspaceFolder},
            // ${file}, ${relativeFile}, ${fileBasename}, etc.
            // Run this first if a task path or variable is not resolving as expected.
            "label": "echo predefined variables",
            "detail": "Print all VS Code predefined variables to the terminal",
            "type": "shell",
            "command": "echo workspaceFolder: ${workspaceFolder} && echo workspaceFolderBasename: ${workspaceFolderBasename} && echo file: ${file} && echo fileWorkspaceFolder: ${fileWorkspaceFolder} && echo relativeFile: ${relativeFile} && echo relativeFileDirname: ${relativeFileDirname} && echo fileBasename: ${fileBasename} && echo fileBasenameNoExtension: ${fileBasenameNoExtension} && echo fileDirname: ${fileDirname} && echo fileExtname: ${fileExtname} && echo cwd: ${cwd}",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Builds a single ROS 2 package in Release mode instead of the whole workspace.
            // When launched, VS Code shows a text input box at the top of the editor
            // where you type the package name (e.g. "my_robot_bringup").
            // The typed value is injected into the command via ${input:packageName},
            // which is resolved by the "inputs" section at the bottom of this file.
            // Uses the same rosbuild defaults as the full workspace build
            // (release mixin, compile-commands, merge-install, symlink-install).
            "label": "build package",
            "detail": "colcon build for a single package (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --packages-select ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Same as "build package" but compiles with debug symbols (-g, no optimization).
            // Use when you need to debug a specific package without rebuilding the whole workspace.
            "label": "build package Debug",
            "detail": "colcon build --mixin debug for a single package (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --mixin debug --packages-select ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Same as "build package" but with release optimizations AND debug symbols.
            // Good balance when you want performance but still need stack traces or breakpoints.
            "label": "build package RelWithDebInfo",
            "detail": "colcon build --mixin rel-with-deb-info for a single package (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --mixin rel-with-deb-info --packages-select ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Builds a package AND all its transitive dependencies in Release mode.
            // Unlike "build package" which only compiles the named package,
            // this resolves the full dependency chain and builds everything needed
            // for that package to link and run correctly.
            // Ideal when cloning a new package into src/ for the first time.
            "label": "build package up-to",
            "detail": "colcon build --packages-up-to (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --packages-up-to ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Same as "build package up-to" but with debug symbols.
            // Builds the package and all its dependencies with debug information.
            "label": "build package up-to Debug",
            "detail": "colcon build --mixin debug --packages-up-to (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --mixin debug --packages-up-to ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Same as "build package up-to" but with release optimizations AND debug symbols.
            // Builds the package and all its dependencies with RelWithDebInfo configuration.
            "label": "build package up-to RelWithDebInfo",
            "detail": "colcon build --mixin rel-with-deb-info --packages-up-to (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --mixin rel-with-deb-info --packages-up-to ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Runs the test suite for a single package and immediately prints the results.
            // The package must have been built first (rosbuild generates the test targets).
            // colcon test runs the tests; colcon test-result --verbose prints the details
            // of any failures, including the test name, output, and error messages.
            // Test results are stored in log/latest_test/<package_name>/.
            "label": "test package",
            "detail": "colcon test + test-result for a single package (prompts for package name)",
            "type": "shell",
            "command": "colcon test --packages-select ${input:packageName} && colcon test-result --verbose",
            "group": "test",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Builds the entire workspace in Release mode, skipping one specific package.
            // Useful when a package is broken and you need to keep the rest of the workspace
            // compiling and running while the issue is investigated.
            // The ignored package stays in src/ and is not deleted — just excluded from this build.
            "label": "build ignore package",
            "detail": "colcon build --packages-ignore (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --packages-ignore ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Same as "build ignore package" but with debug symbols.
            // Builds the whole workspace in Debug mode, skipping the named package.
            "label": "build ignore package Debug",
            "detail": "colcon build --mixin debug --packages-ignore (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --mixin debug --packages-ignore ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Same as "build ignore package" but with release optimizations AND debug symbols.
            // Builds the whole workspace in RelWithDebInfo mode, skipping the named package.
            "label": "build ignore package RelWithDebInfo",
            "detail": "colcon build --mixin rel-with-deb-info --packages-ignore (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --mixin rel-with-deb-info --packages-ignore ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Lists all packages discovered by colcon in the workspace, one per line.
            // Useful to verify which packages colcon sees before launching a build,
            // and to get the exact package name to use in the "build package" tasks.
            // Output format: <package_name> (colcon package type) [relative/path]
            "label": "list packages",
            "detail": "colcon list --names-only — show all packages in the workspace",
            "type": "shell",
            "command": "colcon list --names-only",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Runs the test suite for the entire workspace and prints a full results summary.
            // All packages must have been built first.
            // colcon test runs all registered test targets (gtest, pytest, ament_lint, etc.).
            // colcon test-result --verbose then prints a detailed report of every failure,
            // including test name, output, and error messages.
            // Results are stored in log/latest_test/.
            "label": "test workspace",
            "detail": "colcon test + test-result --verbose for the entire workspace",
            "type": "shell",
            "command": "colcon test && colcon test-result --verbose",
            "group": "test",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Generates a dependency graph of all packages in the workspace and opens it as a PNG.
            // Requires graphviz (dot) — already available in this Dev Container.
            // Useful to understand the build order, spot long dependency chains,
            // and detect unexpected or circular dependencies.
            // The PNG is written to /tmp/colcon_deps.png.
            // xdg-open is not available inside the Dev Container — copy the file to the host
            // or open it with: code /tmp/colcon_deps.png (VS Code image preview).
            "label": "dependency graph",
            "detail": "colcon graph --dot | dot -Tpng → /tmp/colcon_deps.png",
            "type": "shell",
            "command": "colcon graph --dot | dot -Tpng -o /tmp/colcon_deps.png && echo 'Graph saved to /tmp/colcon_deps.png — open with: code /tmp/colcon_deps.png'",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Installs all system dependencies declared in the package.xml files of every
            // package under src/. Run this after cloning the repository into a fresh
            // Dev Container, or after adding a new dependency to a package.xml.
            // --from-paths src   : scan src/ for package.xml files
            // --ignore-src       : skip packages that are already present in src/ (avoid
            //                      installing them as system packages when they are built locally)
            // -r                 : continue on individual package failures (non-fatal errors)
            // -y                 : answer yes to all prompts automatically
            "label": "rosdep install",
            "detail": "rosdep install --from-paths ${workspaceFolder}/src --ignore-src -r -y",
            "type": "shell",
            "command": "sudo rosdep install --from-paths ${workspaceFolder}/src --ignore-src -r -y",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Builds only the packages that directly or transitively depend on the named package.
            // The opposite of "build package up-to": instead of building a package and its deps,
            // this rebuilds everything downstream that would be affected by a change to that package.
            // Useful after modifying a shared library or a message definition — recompiles only
            // the consumers, not the whole workspace.
            "label": "build packages above",
            "detail": "colcon build --packages-above (prompts for package name)",
            "type": "shell",
            "command": "rosbuild --packages-above ${input:packageName}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Shows the results of the last colcon test run without re-running any tests.
            // Reads the XML result files written to log/latest_test/ by the previous test run.
            // Use this to re-read test output after a run has already completed,
            // or to check results from a CI run copied into the log/ directory.
            "label": "test results",
            "detail": "colcon test-result --verbose — show results of the last test run",
            "type": "shell",
            "command": "colcon test-result --verbose",
            "group": "test",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Kills all running ROS 2 nodes launched via ros2 run or ros2 launch.
            // Useful when a node hangs and does not respond to Ctrl+C,
            // or when a launch file leaves orphan processes after being interrupted.
            // The "|| true" prevents the task from failing when no matching process is found.
            "label": "kill ros nodes",
            "detail": "pkill all ros2 run and ros2 launch processes",
            "type": "shell",
            "command": "pkill -f 'ros2 run' || true && pkill -f 'ros2 launch' || true",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Runs the ROS 2 environment diagnostic tool.
            // Checks: ROS distro, DDS middleware, network interfaces, ROS_DOMAIN_ID,
            // node discovery, and common misconfigurations.
            // --report prints the full diagnostic output instead of just the summary.
            // Run this when nodes cannot find each other, topics are missing,
            // or the environment seems misconfigured after a container restart.
            "label": "ros2 doctor",
            "detail": "ros2 doctor --report — full ROS 2 environment diagnostic",
            "type": "shell",
            "command": "ros2 doctor --report",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Lists all active ROS 2 topics currently being published or subscribed to.
            // Requires at least one ROS 2 node to be running.
            // Useful as a quick sanity check to verify that nodes are publishing
            // the expected topics after launching a system.
            "label": "ros2 topic list",
            "detail": "ros2 topic list — show all active topics",
            "type": "shell",
            "command": "ros2 topic list",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Lists all active ROS 2 nodes currently running in the system.
            // Requires the ROS 2 daemon or at least one running node.
            // Use this to verify that all expected nodes are up after a launch,
            // or to find the exact node name for ros2 node info.
            "label": "ros2 node list",
            "detail": "ros2 node list — show all active nodes",
            "type": "shell",
            "command": "ros2 node list",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Runs clang-tidy static analysis on the whole workspace using the
            // compile_commands.json generated by the last build.
            // Reports warnings and errors for each source file directly in the terminal.
            // Requires a prior build so that compile_commands.json exists.
            // run-clang-tidy is a helper script from the clang-tools package that runs
            // clang-tidy in parallel across all files listed in compile_commands.json.
            "label": "clang-tidy workspace",
            "detail": "run-clang-tidy using compile_commands.json",
            "type": "shell",
            "command": "run-clang-tidy -p ${workspaceFolder}/build",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Lists all available ROS 2 interface types: messages (.msg), services (.srv),
            // and actions (.action) registered in the current environment.
            // Useful when writing code and you need the exact type name, e.g.
            // "geometry_msgs/msg/Twist" or "std_srvs/srv/Empty".
            "label": "ros2 interface list",
            "detail": "ros2 interface list — show all available msg, srv and action types",
            "type": "shell",
            "command": "ros2 interface list",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Dumps all parameters of a running ROS 2 node to YAML format.
            // Useful to inspect the current parameter values of a node at runtime,
            // generate a parameter file for future launches, or compare configs.
            // The node name must match exactly as shown in "ros2 node list"
            // (e.g. /my_namespace/my_node_name).
            "label": "ros2 param dump",
            "detail": "ros2 param dump <node> — dump all parameters of a running node to YAML",
            "type": "shell",
            "command": "ros2 param dump ${input:nodeName}",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Applies clang-format to all C/C++ source files under src/ in-place.
            // Uses -style=file so clang-format searches for a .clang-format file
            // walking up the directory tree from each source file.
            // This formats the entire codebase in one shot — different from the
            // per-save formatting configured in ws.code-workspace, which only
            // formats modified lines.
            // Run before committing to ensure consistent formatting across all files.
            "label": "format workspace",
            "detail": "clang-format -i on all .cpp .hpp .h .c files under src/",
            "type": "shell",
            "command": "find ${workspaceFolder}/src -type f \\( -name '*.cpp' -o -name '*.hpp' -o -name '*.h' -o -name '*.c' \\) | xargs clang-format -i -style=file",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Lists all active ROS 2 services currently advertised by running nodes.
            // Complements "ros2 topic list" for systems that communicate via request/response.
            // Use "ros2 service type <service>" to inspect the type of a specific service.
            "label": "ros2 service list",
            "detail": "ros2 service list — show all active services",
            "type": "shell",
            "command": "ros2 service list",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            // Lists all active ROS 2 action servers currently running.
            // Relevant for systems using nav2, MoveIt, or any long-running goal-based interface.
            // Use "ros2 action info <action>" to inspect the type and goal/result/feedback fields.
            "label": "ros2 action list",
            "detail": "ros2 action list — show all active action servers",
            "type": "shell",
            "command": "ros2 action list",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        }
        // Reference commands — not wired as tasks because they need manual setup:
        //
        // Build without stopping on first error (see all broken packages at once):
        //   rosbuild --continue-on-error
        //
        // Run a node under valgrind to detect memory leaks:
        //   valgrind --leak-check=full --track-origins=yes ros2 run <package> <executable>
    ],
    // Input definitions used by tasks that need runtime user input.
    // "promptString" shows a free-text input box — no predefined list to maintain.
    // The "id" must match the ${input:<id>} placeholder used in the task command above.
    "inputs": [
        {
            "id": "packageName",
            "type": "promptString",
            "description": "Package name to build"
        },
        {
            "id": "nodeName",
            "type": "promptString",
            "description": "ROS 2 node name (as shown in ros2 node list, e.g. /my_namespace/my_node)"
        }
    ]
}
