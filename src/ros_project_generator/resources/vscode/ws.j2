{
  "folders": [
    {
      "path": ".",
      "name": "{{ project_id }}"
    },
  ],
  "settings": {
    "editor.autoIndent": "full",
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.detectIndentation": true,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "editor.formatOnType": true,
    "editor.lineNumbers": "relative",
    "editor.rulers": [
      120
    ],
    "files.associations": {
      "*.config": "properties",
      "*.json": "jsonc",
      "*.launch": "xml",
      "*.sdf": "xml",
      "*.urdf": "xml",
      "*.xacro": "xml",
      "*.world": "xml",
      "*.j2": "jinja",
      "*.jinja": "jinja"
    },
    "files.autoSave": "onFocusChange",
    "files.exclude": {
      "/.git": true,
      "/.svn": true,
      "/.hg": true,
      "/.DS_Store": true,
      "src/0_deps/": true,
      "**/__pycache__": true,
      "**/.pytest_cache": true,
      "**/.mypy_cache": true,
      "**/.ruff_cache": true,
      "**/.cache": true,
      "**/.idea": true,
      "**/CMakeFiles": true,
      "**/CMakeCache.txt": true,
      "**/Thumbs.db": true,
    },
    "files.watcherExclude": {
      "build/": true,
      "install/": true,
      "devel/": true,
      "log/": true,
      "logs/": true,
      "**/.git/**": true,
      "src/0_deps/**": true,
      "**/__pycache__/**": true,
      "**/.pytest_cache/**": true,
      "**/.mypy_cache/**": true,
      "**/.ruff_cache/**": true,
      "**/.cache/**": true,
      "**/.idea/**": true,
      "**/CMakeFiles/**": true,
      "**/CMakeCache.txt": true
    },
    "files.saveConflictResolution": "overwriteFileOnDisk",
    "files.trimTrailingWhitespace": true,
    "search.exclude": {
      "/node_modules": true,
      "/bower_components": true,
      "src/0_deps/": true,
      "**/.git/**": true,
      "/*.code-search": true,
      "**/__pycache__/**": true,
      "**/.pytest_cache/**": true,
      "**/.mypy_cache/**": true,
      "**/.ruff_cache/**": true,
      "**/.cache/**": true,
      "**/.idea/**": true,
      "**/CMakeFiles/**": true,
      "**/CMakeCache.txt": true
    },
    // ==========================================================================
    // SHELL SETTINGS
    // NOTE: foxundermoon.shell-format requires shfmt: sudo apt install shfmt
    // NOTE: timonwong.shellcheck requires shellcheck: sudo apt install shellcheck
    // ==========================================================================
    "[shellscript]": {
      "editor.defaultFormatter": "foxundermoon.shell-format"
    },
    // Use 4-space indentation in shell scripts (shfmt -i 4).
    "shellformat.flag": "-i 4",
    // Run shellcheck on save, not on every keystroke.
    "shellcheck.run": "onSave",
    // ==========================================================================
    // CPP SETTINGS
    // ==========================================================================
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.loggingLevel": "Warning",
    // Show squiggles in c_cpp_properties.json when configured paths do not exist.
    "C_Cpp.default.enableConfigurationSquiggles": true,
    "[c]": {
      "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[cpp]": {
      "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "C_Cpp.formatting": "clangFormat",
    "C_Cpp.clang_format_style": "file",
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.codeAnalysis.runAutomatically": false,
    "C_Cpp.codeAnalysis.clangTidy.path": "/usr/bin/clang-tidy",
    "C_Cpp.codeAnalysis.clangTidy.useBuildPath": true,
    // Configure glob patterns for excluding folders and files for code analysis.
    "C_Cpp.codeAnalysis.exclude": {
      "**/build": true,
      "**/devel": true,
      "**/install": true,
      "**/log": true,
      "**/.git": true
    },
    // ==========================================================================
    // CMAKE SETTINGS
    // ==========================================================================
    "[cmake]": {
      "editor.defaultFormatter": "cheshirekow.cmake-format"
    },
    // ==========================================================================
    // PYTHON SETTINGS
    // ==========================================================================
    "python.analysis.autoFormatStrings": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.extraPaths": [
      "/opt/ros/{{ ros_distro }}/lib/python{{ python_version }}/site-packages"
    ],
    "python.analysis.typeCheckingMode": "standard",
    "python.analysis.useLibraryCodeForTypes": true,
    "[python]": {
      "editor.defaultFormatter": "charliermarsh.ruff",
      "editor.formatOnSave": true,
      "editor.formatOnSaveMode": "modificationsIfAvailable",
      "editor.codeActionsOnSave": {
        "source.fixAll.ruff": "always",
        "source.organizeImports": "never",
        "source.organizeImports.ruff": "always"
      }
    },
    // ==========================================================================
    // CMAKE TOOLS
    // ==========================================================================
    // Disable auto-configure: in ROS 2 the build is driven by colcon, not cmake directly.
    "cmake.configureOnOpen": false,
    "cmake.buildDirectory": "${workspaceFolder}/build/${buildType}",
    "cmake.generator": "Ninja",
    // ==========================================================================
    // CODE SPELL CHECKER
    // ==========================================================================
    "cSpell.language": "en,es",
    "cSpell.ignorePaths": [
      "build/",
      "install/",
      "log/",
      "src/0_deps/"
    ],
    // ==========================================================================
    // DOX DOC GEN
    // ==========================================================================
    "doxdocgen.generic.authorName": "jfrascon",
    "doxdocgen.generic.authorEmail": "jfrascon@gmail.com",
    "doxdocgen.file.fileOrder": [
      "file",
      "brief",
      "author",
      "date"
    ],
    "doxdocgen.generic.order": [
      "brief",
      "param",
      "return"
    ],
    // ==========================================================================
    // ERROR LENS
    // ==========================================================================
    // Show inline diagnostics only for errors and warnings; hints are too noisy.
    "errorLens.enabledDiagnosticLevels": [
      "error",
      "warning"
    ],
    // Delay decoration updates to avoid flickering while typing.
    "errorLens.delay": 500,
    // ==========================================================================
    // GIT
    // ==========================================================================
    "git.autofetch": true,
    "git.ignoreLimitWarning": true,
    // ==========================================================================
    // ROS
    // ==========================================================================
    "ROS2.distro": "{{ ros_distro }}",
    // ==========================================================================
    // RUFF
    // ==========================================================================
    //"ruff.configuration": leave it empty to use the pyproject.toml file of each repo.
    "ruff.importStrategy": "fromEnvironment",
    "ruff.nativeServer": "on",
    "ruff.organizeImports": true,
    // ==========================================================================
    // YAML SETTINGS
    // ==========================================================================
    "[yaml]": {
      "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    // Match the column ruler at 120.
    "yaml.format.printWidth": 120,
    // ==========================================================================
    // MARKDOWN SETTINGS
    // ==========================================================================
    "[markdown]": {
      "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
      "editor.formatOnSave": true
    },
    // ==========================================================================
    // TOML SETTINGS
    // ==========================================================================
    "[toml]": {
      "editor.defaultFormatter": "tamasfe.even-better-toml"
    },
    // ==========================================================================
    // XML SETTINGS
    // ==========================================================================
    "[xml]": {
      "editor.defaultFormatter": "redhat.vscode-xml"
    },
    "xml.format.maxLineWidth": 0,
    "xml.format.splitAttributes": "preserve",
    "xml.format.closingBracketNewLine": false,
    "xml.format.spaceBeforeEmptyCloseTag": false,
    "python.autoComplete.extraPaths": [
      "/opt/ros/{{ ros_distro }}/lib/python{{ python_version }}/site-packages"
    ],
  }
}
